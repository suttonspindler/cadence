# ---------------------------------------------------------------------------
# Cadence — environment configuration. Copy to .env and fill in.
# ---------------------------------------------------------------------------

# Postgres (matches docker-compose.yml). The pgvector-enabled image is used.
POSTGRES_USER=cadence
POSTGRES_PASSWORD=cadence
POSTGRES_DB=cadence
POSTGRES_PORT=5432

# Connection string consumed by Prisma (web) and SQLAlchemy (ai).
DATABASE_URL=postgresql://cadence:cadence@localhost:5432/cadence?schema=public

# --- AI providers -----------------------------------------------------------
# Generation: Anthropic Claude (assistant, review summaries, recommendation reasoning)
ANTHROPIC_API_KEY=
CADENCE_LLM_MODEL=claude-opus-4-8

# Embeddings provider: local | voyage | openai | hash
#   local  = self-hosted sentence-transformers model (default; no key, no rate limits, offline)
#   voyage = Voyage AI cloud (set VOYAGE_API_KEY)
#   openai = OpenAI cloud (set OPENAI_API_KEY)
#   hash   = dependency-free fallback (lexical only)
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_DIM=1024
LOCAL_EMBEDDINGS_MODEL=mixedbread-ai/mxbai-embed-large-v1
# Cloud model id (used when provider is voyage/openai)
EMBEDDINGS_MODEL=voyage-3.5
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Service URLs -----------------------------------------------------------
# Next.js calls the Python AI service over HTTP.
AI_SERVICE_URL=http://localhost:8000

# --- Auth (Auth.js / NextAuth v5) -------------------------------------------
# Generate a secret with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=dev-secret-change-me
AUTH_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Dev-only login button (email/name, no provider needed). Set to "false" in production.
ENABLE_DEV_LOGIN=true
